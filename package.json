{
  "name": "slides",
  "version": "0.1.0",
  "private": true,
  "description": "slides - Slidev presentations monorepo",
  "type": "module",
  "scripts": {
    "dev": "supaslidev",
    "new": "supaslidev new",
    "present": "supaslidev present",
    "export": "supaslidev export",
    "deploy": "supaslidev deploy",
    "build": "pnpm --filter @supaslidev/* run build",
