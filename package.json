  "devDependencies": {
    "nuxt": "catalog:core",
    "playwright-chromium": "catalog:",
    "supaslidev": "^0.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.28.1"
}
